  "claim": {
    "id": "CLM-52",
    "text": "ZenX Capital, a.s. (IČO 09289127; Zdeněk Sluka is a member of its správní rada since 2020 per the primary register) has been Able.cz s.r.o.'s largest shareholder since 14 October 2020: 50.0 % (2020–2023), 47.5 % (2023–2024), 48.2 % (2024–2025), and 45.80 % since 29 July 2025.",
    "status": "VERIFIED_PRIMARY",
    "note": "The mirror-based pass recorded ZenX as one flat vklad among others and missed the scale of the holding entirely.",
    "sources": [
      "SRC-12"
    ]
