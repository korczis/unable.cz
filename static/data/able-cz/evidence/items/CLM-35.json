  "claim": {
    "id": "CLM-35",
    "text": "A family relationship between Václav Faraga (b. 1989) and Petr Faraga (b. 1966) is plausible — shared surname, shared Znojmo address cluster, co-founding of Able.cz/BIT CONSULTING in 2012, and co-holdings in FaMe logistics and FaMe trade — but no public source states it. The same applies to Martin Patrik Faraga (FaMe logistics' founding co-owner).",
    "status": "ASSESSED",
    "note": "Assessment only; the relationship itself remains NOT_FOUND in public sources.",
    "sources": [
      "SRC-12",
      "SRC-10"
    ]
  },
